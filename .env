# ConsolidaTrack — Environment Configuration
FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=change-this-to-a-random-secret-key

# Database
DATABASE_URL=sqlite:///consolidatrack.db

# SeaRates API
SEARATES_API_KEY=your-searates-api-key-here
SEARATES_BASE_URL=https://api.searates.com/v1

# Tracking scheduler (hours between updates)
TRACKING_INTERVAL_HOURS=6

# Tolerance for proportional validation (decimal, e.g. 0.01 = 1%)
PROPORTIONAL_TOLERANCE=0.01

# Admin user (created on first seed)
ADMIN_EMAIL=admin@consolidatrack.com
ADMIN_PASSWORD=changeme123
